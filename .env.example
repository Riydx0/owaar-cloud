# ─────────────────────────────────────────────
# OWAAR CLOUD — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# PostgreSQL Database
POSTGRES_DB=owaar_cloud
POSTGRES_USER=owaar
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# API Server
API_PORT=3000
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET_MIN_32_CHARS

# Frontend
FRONTEND_PORT=4000
API_URL=https://api.yourdomain.com

# Optional: Full DATABASE_URL (auto-generated from above if using docker-compose)
# DATABASE_URL=postgresql://owaar:password@db:5432/owaar_cloud
